{
  "manifest_version": 3,
  "name": "OneText",
  "version": "3.0",
  "description": "Real Note-Taking Extension",
  "author": "hello@irfanfadilah.com",
  "action": {
    "default_title": "OneText - Click to Open"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "windows": "Ctrl+Space",
        "mac": "Command+Space",
        "chromeos": "Ctrl+Space",
        "linux": "Ctrl+Space"
      }
    }
  },
  "permissions": ["sidePanel"],
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "128": "icon.png"
  }
}
